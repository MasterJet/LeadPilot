# LeadPilot Unified .gitignore

# Dependencies
node_modules/
node_module/
frontend/node_modules/
frontend/node_module/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Python virtual environments & runtimes
.venv/
venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
*.egg-info/

# Next.js & Frontend build outputs
.next/
frontend/.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Docker Compose Local Settings
docker-compose.override.yml
docker-compose.local.yml
docker-compose.dev.yml

# IDEs, Editors, & OS Files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
Thumbs.db

# Logs & Diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Credentials, Keys, & Environment Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env.secret
*.pem
*.key

# SQLite Databases & Local Storage
*.db
*.sqlite
*.sqlite3

# Large Media & Automation Recordings
recordings/
*.webm
*.mp4
*.mkv
*.avi
